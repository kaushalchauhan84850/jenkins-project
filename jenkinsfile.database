pipeline {
    agent { label 'electronix' }

    stages {
        stage('Creating Database') {
            steps {
                sh 'python3 scripts/create-db.py'
            }
        }
    }

    post {
        success {
            echo 'Database created successfully ✅'
        }

        failure {
            echo 'Database creation failed ❌'
        }
    }
}